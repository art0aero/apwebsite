PROJECT_NAME=ap-supabase
INSTALL_DIR=/opt/ap-supabase
SUPABASE_REPO_TAG=v2.39.2

# Public URLs (set your domain or IP-based URLs)
SUPABASE_PUBLIC_URL=https://supabase.example.com
STUDIO_PUBLIC_URL=https://studio.example.com

# Required secrets
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me_long_random_string
ANON_KEY=change_me_anon_jwt
SERVICE_ROLE_KEY=change_me_service_jwt
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_dashboard_password

# Optional: SMTP for auth emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
